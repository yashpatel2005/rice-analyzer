{
  "buildCommand": "python3 build_static.py",
  "outputDirectory": "dist",
  "devCommand": "echo 'Static site'",
  "installCommand": "pip install --break-system-packages Jinja2",
  "framework": null,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}